<script type="text/javascript">
(function waitTawkStatus() {
    if (window.Tawk_API && typeof Tawk_API.onStatusChange === 'function') {
        var srcOnline = "https://suzukicdn.com/themes/default2019/img/icon-chat-online.webp";
        var srcOffline = "https://suzukicdn.com/themes/default2019/img/icon-chat-offline.webp";

        Tawk_API.onStatusChange = function(status) {
            var imgs = document.querySelectorAll('#status img');
            imgs.forEach(function(img) {
                if (status === 'online') {
                    img.src = srcOnline;
                } else if (status === 'away' || status === 'offline') {
                    img.src = srcOffline;
                }
            });
        };
    } else {
        setTimeout(waitTawkStatus, 400);
    }
})();
</script>

<!-- CSS untuk Floating Menu Revamp -->
<style type="text/css">
/* Container Utama */
.floating-menu-revamp {
    position: fixed;
    right: 4%;
    bottom: 50%;
    transform: translate(50%, 50%);
    z-index: 9999;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
}

/* Menu Items Container */
.floating-menu-items {
    width: 87px;
    background-color: #0549A8;
    border-radius: 24px 24px 0 0;
    padding: 9px;
    box-shadow: 0 2.959px 2.959px 0 rgba(0, 0, 0, 0.25);
    transform-origin: bottom center;
    transform: translateY(8px) scaleY(0);
    opacity: 0;
    transition: transform 0.38s cubic-bezier(0.22, 1, 0.36, 1), opacity 0.28s ease;
    will-change: transform, opacity;
    pointer-events: none;
    overflow: hidden;
    margin-bottom: -11px;
}

/* Menu Items - Expanded State */
.floating-menu-items.expanded {
    transform: translateY(0) scaleY(1);
    opacity: 1;
    pointer-events: auto;
}

/* Individual Menu Items */
.floating-menu-items a {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
    color: white;
    text-decoration: none;
    font-size: 9px;
    font-weight: 500;
    transition: all 0.2s ease;
    backdrop-filter: blur(10px);
    will-change: transform, opacity;
}

.floating-menu-items a:not(:last-child) {
    margin-bottom: 18px;
}

.floating-menu-items a:hover {
    transform: translateX(-5px);
}

.floating-toggle-btn {
    width: 60px;
    height: 60px;
    border-radius: 50%;
    background-color: #0549A8;
    border: none;
    color: white;
    font-size: 24px;
    font-weight: bold;
    cursor: pointer;
    box-shadow: 0 2.959px 2.959px 0 rgba(0, 0, 0, 0.25);
    transition: all 0.3s ease;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 10000;
    position: relative;
}

.floating-toggle-btn.expanded {
    width: 87px;
    height: 60px;
    border-radius: 0 0 24px 24px;
}

/* Inner ring border pada tombol + */
.floating-toggle-btn::before {
    content: "";
    position: absolute;
    inset: 0;
    width: 54%;
    height: 54%;
    margin: auto;
    border: 3px solid #ffffff;
    border-radius: 50%;
    pointer-events: none;
    transition: all 0.3s ease;
}

.floating-toggle-btn.expanded::before {
    width: 38%;
    height: 54%;
}

/* Pulse animation saat collapse */
.floating-toggle-btn:not(.expanded) {
    animation: pulse 1.5s ease-in-out infinite;
}

/* Pulse animation keyframes */
@keyframes pulse {
    0% {
        box-shadow: 0 2.959px 2.959px 0 rgba(0, 0, 0, 0.25), 0 0 0 0 rgba(5, 73, 168, 0.7);
    }
    50% {
        box-shadow: 0 2.959px 2.959px 0 rgba(0, 0, 0, 0.25), 0 0 0 10px rgba(5, 73, 168, 0.3);
    }
    100% {
        box-shadow: 0 2.959px 2.959px 0 rgba(0, 0, 0, 0.25), 0 0 0 0 rgba(5, 73, 168, 0.7);
    }
}


/* Toggle Icon Animation */
.toggle-icon {
    transition: transform 0.3s ease;
}

.floating-toggle-btn.expanded .toggle-icon {
    transform: none;
}

/* Chat Button */
.flbtnchat {
    width: 60px;
    height: 60px;
    border-radius: 50%;
    background-color: white;
    color: #1e3a8a;
    text-decoration: none;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    font-size: 12px;
    font-weight: 600;
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.2);
    transition: all 0.3s ease;
    position: relative;
    z-index: 10000;
}

.flbtnchat:hover {
    background-color: #f8fafc;
    transform: scale(1.05);
    color: #1e40af;
}

.flbtnchat:active {
    transform: scale(0.95);
}

/* Responsive Design */
@media (max-width: 768px) {
    .floating-menu-revamp {
        right: 50%;
        bottom: 50%;
        transform: translate(50%, 50%);
    }
    
    .floating-toggle-btn,
    .flbtnchat {
        width: 50px;
        height: 50px;
        font-size: 20px;
    }
    
    .floating-menu-items {
        padding: 10px;
        max-width: 90vw;
    }
    
    .floating-menu-items a {
        padding: 10px 12px;
        font-size: 13px;
    }
}

/* Animation untuk menu items muncul dari bawah */
.floating-menu-items a {
    transform: translateY(20px);
    opacity: 0;
    transition: all 0.6s ease;
}

.floating-menu-items.expanded a {
    transform: translateY(0);
    opacity: 1;
}

/* Staggered animation untuk setiap item */
.floating-menu-items.expanded a:nth-child(1) { transition-delay: 0.2s; }
.floating-menu-items.expanded a:nth-child(2) { transition-delay: 0.3s; }
.floating-menu-items.expanded a:nth-child(3) { transition-delay: 0.4s; }
.floating-menu-items.expanded a:nth-child(4) { transition-delay: 0.5s; }
.floating-menu-items.expanded a:nth-child(5) { transition-delay: 0.6s; }
.floating-menu-items.expanded a:nth-child(6) { transition-delay: 0.7s; }
</style>

<!-- JavaScript untuk Toggle Functionality -->
<script type="text/javascript">
document.addEventListener('DOMContentLoaded', function() {
    const toggleBtn = document.getElementById('floatingToggleBtn');
    const menuItems = document.getElementById('floatingMenuItems');
    const toggleIcon = toggleBtn.querySelector('.toggle-icon');
    
    let isExpanded = true;
    
    function closeMenuWithSyncButton() {
        if (!menuItems.classList.contains('expanded')) return;
        isExpanded = false;
        // Mulai animasi collapse pada menu
        menuItems.classList.remove('expanded');
        
        // Tunda perubahan state tombol sampai animasi selesai (transitionend transform)
        const onTransitionEnd = function(event) {
            if (event.target !== menuItems) return;
            if (event.propertyName !== 'transform') return;
            // Lepas listener segera agar tidak menumpuk saat klik cepat
            menuItems.removeEventListener('transitionend', onTransitionEnd);
            if (isExpanded) return; // Jika sudah dibuka lagi, jangan ubah tombol
            toggleBtn.classList.remove('expanded');
            toggleIcon.textContent = '+';
        };
        menuItems.addEventListener('transitionend', onTransitionEnd);
    }
    
    toggleBtn.addEventListener('click', function() {
        if (!isExpanded) {
            // Expand
            isExpanded = true;
            menuItems.classList.add('expanded');
            toggleBtn.classList.add('expanded');
            toggleIcon.textContent = '−';
        } else {
            // Collapse (tombol tetap expanded sampai animasi selesai)
            closeMenuWithSyncButton();
        }
    });
});
</script>


