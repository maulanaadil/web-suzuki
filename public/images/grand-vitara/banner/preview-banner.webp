    text-align: center;
    font-weight: 300;
    font-size: 16px;
    border: 1px solid #001151;
    transition: 0.3s ease;
    -webkit-transition: 0.3s ease;
    -moz-transition: 0.3s ease;
    -ms-transition: 0.3s ease;
    -o-transition: 0.3s ease;
}
header {
    background: #2828285e;
}
</style>

<script>
document.addEventListener('DOMContentLoaded', () => {
    let offset = 7;
    const base_url = 'https://www.suzuki.co.id/';
    const data = [{"id":116,"slug":"back-door-garnish-chrome","part_no":"990J0M76T13-010","name":"Back Door Garnish (Chrome)","description":"","price":297500,"image":"https:\/\/www.suzuki.co.id\/uploads\/aksesoris_product\/automobile\/Back_Door_Garnish11.webp","image_alt":"Back Door Garnish (Chrome)","image_title":"Back Door Garnish (Chrome)","status":1},{"id":117,"slug":"body-side-moulding-chrome","part_no":"990J0M76T01-010","name":"Body Side Moulding (Chrome)","description":"","price":706500,"image":"https:\/\/www.suzuki.co.id\/uploads\/aksesoris_product\/automobile\/Body_Side_Moulding_(Chrome)21.webp","image_alt":"Body Side Moulding (Chrome)","image_title":"Body Side Moulding (Chrome)","status":1},{"id":118,"slug":"carpet-floor-mat-premium","part_no":"75901M76T30-000","name":"Carpet Floor Mat - Premium","description":"","price":767500,"image":"https:\/\/www.suzuki.co.id\/uploads\/aksesoris_product\/automobile\/Carpet_Floor_Mat_-_Premium11.webp","image_alt":"Carpet Floor Mat - Premium","image_title":"Carpet Floor Mat - Premium","status":1},{"id":119,"slug":"door-sill-guard","part_no":"990J0M76TM8-010","name":"Door Sill Guard","description":"","price":679500,"image":"https:\/\/www.suzuki.co.id\/uploads\/aksesoris_product\/automobile\/Door_Sill_Guard21.webp","image_alt":"Door Sill Guard","image_title":"Door Sill Guard","status":1},{"id":120,"slug":"front-bumper-extender-black--chrome","part_no":"990J0M76T07-010","name":"Front Bumper Extender (Black + Chrome)","description":"","price":789000,"image":"https:\/\/www.suzuki.co.id\/uploads\/aksesoris_product\/automobile\/Front_Bumper_Extender11.webp","image_alt":"Front Bumper Extender (Black + Chrome)","image_title":"Front Bumper Extender (Black + Chrome)","status":1},{"id":121,"slug":"front-skid-garnish","part_no":"990J0M76T13-030","name":"Front Skid Garnish","description":"","price":177500,"image":"https:\/\/www.suzuki.co.id\/uploads\/aksesoris_product\/automobile\/Front_Skid_Garnish11.webp","image_alt":"","image_title":"","status":1},{"id":122,"slug":"head-lamp-garnish-black","part_no":"990J0M76T13-060","name":"Head Lamp Garnish (Black)","description":"","price":161000,"image":"https:\/\/www.suzuki.co.id\/uploads\/aksesoris_product\/automobile\/Head_Lamp_Garnish11.webp","image_alt":"Head Lamp Garnish (Black)","image_title":"Head Lamp Garnish (Black)","status":1},{"id":123,"slug":"mud-flap","part_no":"72201M76TX0-000","name":"Mud Flap","description":"","price":197500,"image":"https:\/\/www.suzuki.co.id\/uploads\/aksesoris_product\/automobile\/Mud_Flap11.webp","image_alt":"Mud Flap","image_title":"Mud Flap","status":1},{"id":124,"slug":"plain-door-visor","part_no":"990J0M76TQ0-010","name":"Plain Door Visor","description":"","price":546000,"image":"https:\/\/www.suzuki.co.id\/uploads\/aksesoris_product\/automobile\/Plain_Door_Visor11.webp","image_alt":"","image_title":"","status":1},{"id":125,"slug":"pvc-3d-boot-mat","part_no":"990J0M76TA3-010","name":"PVC 3D Boot Mat","description":"","price":613500,"image":"https:\/\/www.suzuki.co.id\/uploads\/aksesoris_product\/automobile\/PVC_3D_Boot_Mat11.webp","image_alt":"","image_title":"","status":1}];
    const theme_url = `https://suzukicdn.com/themes/default2019/`;
    const qSelect = (el) => document.querySelector(el);
    const slug = `grand-vitara`;

    const more_button = qSelect('.button-more');

    more_button.addEventListener('click', () => {
        let html = '';
        data.forEach((item, key) => {
            if ((key > offset) && (key <= (offset + 8))) {
                html += `<div class="card hover-blue">
                                <a
                                    href="${base_url}aksesori/${slug}/${item.id}/${item.slug}">
                                    <img src="${item.image != '' ? item.image : theme_url+'img/accessories/abu.webp'}"
                                        class="card-img-top" alt="${item.image_alt}" title="${item.image_title}">
                                    <div class="card-body">
                                        <h5 class="card-title fm-SuzukiPROBold mb-0">${item.name}</h5>
                                        <p class="text-muted fm-SuzukiPRORegular my-2">${item.part_no}</p>
                                        <p class="card-text fm-SuzukiPROBold  mb-0">Rp${parseInt(item.price).toLocaleString('id-ID')}</p>
                                        <div class="buttons mt-4">
                                            <a href="${base_url}aksesori/${slug}/${item.id}/${item.slug}"
                                                class="fm-SuzukiPROBold text-dark">Lihat Detail <i
                                                    class="bi bi-chevron-right"></i></a>
                                        </div>
                                    </div>
                                </a>
                            </div>`;
            }
        });
        offset += 8;
        qSelect('#product').innerHTML += html;
        if (!data[offset]) {
            more_button.remove();
        }
    });
})
