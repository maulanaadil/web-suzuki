generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model CarModel {
  id            String           @id @default(cuid())
  slug          String           @unique @db.VarChar(255)
  name          String           @db.VarChar(255)
  category      CarCategory?
  vehicleType   CarVehicleType?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  variants      CarVariant[]
  colors        CarColor[]
  images        CarImage[]
  testimonials  Testimonial[]
  orderForms    CarOrderForm[]
  detailBanner  CarDetailBanner[] @relation("CarDetailBanner")
  detailCarousel CarDetailCarousel[] @relation("CarDetailCarousel")
}

model CarVariant {
  id           String     @id @default(cuid())
  carModelId   String
  carModel     CarModel   @relation(fields: [carModelId], references: [id], onDelete: Cascade)
  code         String     @unique
  name         String?
  sortOrder    Int        @default(0)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  specs        CarSpec[]
  price        CarPrice?
  colors       CarColor[]

  @@index([carModelId])
}

model CarSpec {
  id             String     @id @default(cuid())
  carVariantId   String
  carVariant     CarVariant @relation(fields: [carVariantId], references: [id], onDelete: Cascade)
  group          String
  key            String
  value          String
  sortOrder      Int        @default(0)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  @@index([carVariantId])
}

model CarPrice {
  id             String     @id @default(cuid())
  carVariantId   String     @unique
  carVariant     CarVariant @relation(fields: [carVariantId], references: [id], onDelete: Cascade)
  otrPrice       BigInt
  currency       String     @default("IDR")
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
}

model CarColor {
  id               String     @id @default(cuid())
  carModelId       String
  name             String?     @db.Text
  carModel         CarModel   @relation(fields: [carModelId], references: [id], onDelete: Cascade)
  carVariantCode   String
  carVariant       CarVariant @relation(fields: [carVariantCode], references: [code], onDelete: Cascade)
  colorCode        String     @db.VarChar(255)
  type             CarColorType @default(ONE_TONE)
  primaryColorCode String?     @db.VarChar(255)
  secondaryColorCode String?     @db.VarChar(255)
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  @@unique([carVariantCode, colorCode])
  @@index([carModelId])
}

model CarImage {
  id          String       @id @default(cuid())
  carModelId  String
  carModel    CarModel     @relation(fields: [carModelId], references: [id], onDelete: Cascade)
  url         String       @db.VarChar(255)
  type        CarImageType
  contents    CarImageContent?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@unique([carModelId, url])
  @@index([carModelId])
}

model CarImageContent {
  id          String       @id @default(cuid())
  carImageId  String       @unique
  carImage    CarImage?    @relation(fields: [carImageId], references: [id])
  title       String       @db.Text
  content     String       @db.Text
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([carImageId])
}

model Testimonial {
  id          String   @id @default(cuid())
  carModelId  String
  carModel    CarModel @relation(fields: [carModelId], references: [id], onDelete: Cascade)
  name        String   @db.VarChar(255)
  quote       String   @db.VarChar(255)
  imageUrl    String   @db.VarChar(255)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model CarOrderForm {
  id             String   @id @default(cuid())
  carModelId     String
  carModel       CarModel @relation(fields: [carModelId], references: [id], onDelete: Cascade)
  name           String   @db.VarChar(255)
  email          String?  @db.VarChar(255)
  idCardNumber   String   @db.VarChar(255)
  phone          String   @db.VarChar(255)
  city           String?  @db.VarChar(255)
  vehicleType    String?  @db.VarChar(100)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([carModelId])
}

model CarDetailBanner {
  id String @id @default(cuid())
  carModelId String 
  carModel CarModel[] @relation("CarDetailBanner")
  title String @db.VarChar(255)
  bannerVariant CarImageType @default(INTERIOR)
  description String @db.VarChar(255)
  buttonLabel String @db.VarChar(255)
  buttonHref String @db.VarChar(255)
  imageUrl String @db.VarChar(255)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CarDetailCarousel {
  id String @id @default(cuid())
  carModelId String 
  carModel CarModel[] @relation("CarDetailCarousel")
  carouselVariant CarImageType @default(CAROUSEL)
  variant CarDetailCarouselVariant @default(SAFETY)
  carouselContent CarDetailCarouselContent[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CarDetailCarouselContent {
  id String @id @default(cuid())
  carDetailCarouselId String
  carDetailCarousel CarDetailCarousel @relation(fields: [carDetailCarouselId], references: [id], onDelete: Cascade)
  title String @db.Text
  content String @db.Text
  imageUrl String @db.VarChar(255)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Article {
  id        String   @id @default(cuid())
  slug      String   @unique @db.VarChar(255)
  title     String   @db.VarChar(255)
  snippet   String   @db.VarChar(500)
  category  String   @db.VarChar(100)
  content   String   @db.Text
  imageUrl  String   @db.VarChar(255)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum CarColorType {
  ONE_TONE
  SECONDARY
}

enum CarDetailCarouselVariant {
  SAFETY
  SECURITY
  PERFORMANCE
}

enum CarImageType {
  BANNER
  CAROUSEL
  INTERIOR
  PREVIEW
  EKSTERIOR
}

enum CarCategory {
  SUV
  MPV
  CITY_CAR
  COMMERCIAL
}

enum CarVehicleType {
  PASSENGER
  COMMERCIAL
}

